# HTTP web-ui listen address
GITBASE_ADDR=:3000

# Data directory (database + repos)
GITBASE_DATA=/data

# Public URL (set when behind a reverse proxy)
GITBASE_PUBLIC_URL=https://git.example.com

# Max file size to display in bytes (default 5MB)
GITBASE_MAX_BLOB_BYTES=5242880

# SSH server (disabled by default)
SSH_ENABLED=false
SSH_PORT=2222
SSH_HOST=0.0.0.0
